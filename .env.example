# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Resend audience ID — https://resend.com/audiences (create one, copy the ID)
RESEND_AUDIENCE_ID=...

# The "from" address for outbound emails (domain must be verified in Resend)
RESEND_FROM_EMAIL=Pipesight <hello@pipesight.co>

# Your email — receives a notification on every new signup
NOTIFICATION_EMAIL=...
